# Server
PORT=
NODE_ENV=development

# MongoDB Atlas
MONGO_URI=

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=

DATABASE_URL=
# LLM API
OPENAI_API_KEY=

# Query Execution
QUERY_TIMEOUT_MS=5000          # Max time a query can run (ms)
MAX_RESULT_ROWS=500            # Max rows returned to client
SANDBOX_SCHEMA_PREFIX=ws_     # Prefix for per-problem sandbox schemas

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000     # 1 minute
RATE_LIMIT_MAX_REQUESTS=30     # Max requests per window